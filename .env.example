# Credentials template for Google Colab & local notebooks
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to git — it should be in .gitignore

# Massive.com S3 API credentials
# Get these from your Massive.com account dashboard
MASSIVE_S3_ACCESS_KEY=your_access_key_here
MASSIVE_S3_SECRET_KEY=your_secret_key_here

# Optional: Custom S3 endpoint (defaults to https://files.massive.com)
# S3_ENDPOINT=https://files.massive.com
